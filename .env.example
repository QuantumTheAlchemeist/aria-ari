# PostgreSQL connection string (required for API routes)
# Supabase:   postgresql://postgres:[password]@[host]:5432/postgres?sslmode=require
# Local:      postgresql://postgres:password@localhost:5432/receipts
DATABASE_URL=postgresql://user:password@localhost:5432/receipts

# HMAC secret for gated-action approval tokens (min 16 chars, use a strong random value in production)
# The code falls back to an insecure dev-only secret if this is unset — never omit in production.
RECEIPTS_HMAC_SECRET=change-me-to-a-strong-random-secret
